# ─── App ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ─── MongoDB ─────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/e-liprary?retryWrites=true&w=majority

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_at_least_64_chars
JWT_EXPIRES_IN=7d

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Admin Registration ──────────────────────────────────────────────────────
# Secret to allow temporary admin self-registration
ADMIN_SECRET=temporary_admin_secret_123


# ─── Cloudflare R2 ───────────────────────────────────────────────────────────
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=e-liprary-files
# Optional: public custom domain for the bucket (leave empty if not configured)
R2_PUBLIC_URL=

# Signed URL expiry in seconds (default: 300 = 5 minutes)
DOWNLOAD_LINK_EXPIRY_SECONDS=300
